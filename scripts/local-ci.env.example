# Copy this file to scripts/local-ci.env and fill the values for local CI testing.

# Optional local machine paths. Leave blank to use your existing shell environment.
JAVA_HOME=
ANDROID_SDK_ROOT=

# Required for Firebase preparation and distribution.
# Use one of these:
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_FILE=jpn-word-trainer-firebase-adminsdk-fbsvc-b9f21aa44d.json

# At least one of these is required for Firebase App Distribution.
FIREBASE_APP_DISTRIBUTION_TESTERS=
FIREBASE_APP_DISTRIBUTION_GROUPS=

# Required only when the tested flow publishes a GitHub release or downloads a release asset.
WORKFLOW_PUSH_TOKEN=
